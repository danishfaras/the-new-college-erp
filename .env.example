# Database Connection
# Local MongoDB (default for development - run MongoDB locally first):
DATABASE_URL=mongodb://localhost:27017/the_new_college
# For MongoDB Atlas (Cloud) - uncomment and set your cluster URL, and whitelist your IP in Atlas:
# DATABASE_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/the_new_college?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-minimum-32-characters-long-change-in-production

# Email Configuration (SMTP)
# Leave empty if you don't want to send emails (emails will be logged to console in dev mode)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@nextgenedu.edu

# Payment Gateways (Optional - for future integration)
STRIPE_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# App Environment
NODE_ENV=development
