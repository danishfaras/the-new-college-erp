# --- Vercel / production ---
# Set NEXTAUTH_URL to your real site URL, e.g. https://your-app.vercel.app
# (must match the URL users open in the browser, including https)
NEXTAUTH_URL=http://localhost:3000
# Strong random secret; same value in Vercel → Settings → Environment Variables
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Optional; Auth.js also reads AUTH_URL — keep in sync with NEXTAUTH_URL on Vercel
# AUTH_URL=https://your-app.vercel.app

# MongoDB (Atlas: allow access from everywhere 0.0.0.0/0 for serverless IPs, or Vercel static IP add-on)
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/the_new_college?retryWrites=true&w=majority

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@college.edu

NODE_ENV=development
