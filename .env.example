# --- Vercel / production (required) ---
# Exact public URL, e.g. https://your-app.vercel.app (https, no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Auth.js v5: set AUTH_SECRET (preferred). NEXTAUTH_SECRET still works if set instead.
# Use ONE strong value everywhere (e.g. openssl rand -base64 32)
AUTH_SECRET=
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Optional mirror of NEXTAUTH_URL for Auth.js
# AUTH_URL=https://your-app.vercel.app

# MongoDB (Atlas: allow access from everywhere 0.0.0.0/0 for serverless IPs, or Vercel static IP add-on)
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/the_new_college?retryWrites=true&w=majority

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@college.edu

NODE_ENV=development
